#!/usr/bin/env bash

main() {
    sxhkd -c "$HOME/.config/bspwm/sxhkd/sxhkdrc" &

    dunst -config "$HOME/.config/bspwm/dunst/dunstrc" &

    picom --config "$HOME/.config/bspwm/picom/picom.conf" --daemon --experimental-backends

    blueman-applet &

    nextcloud --background &

    xsetroot -cursor_name left_ptr &

    #xwallpaper --daemon --zoom "/home/thomas/Bilder/Wallpapers/Blue-Abstract-Wallpaper-Image-HD.jpg" &>/dev/null
    xwallpaper --daemon --zoom "/home/thomas/Downloads/Wallpaper/28725.jpg" &>/dev/null

    export DEBUG=no
    setsid "$HOME/.config/bspwm/lemonbar/start.sh" -l &
    sleep 0.2
    "$HOME/.config/bspwm/trayer/start_trayer.sh" &

    # activate screensaver after 5 minutes
    xset s 300 10 &
    # activate DPMS
    xset +dpms
    # set DPMS Standby, Suspend, Off
    xset dpms 400 600 900

    XSECURELOCK_DIM_TIME_MS=10000 xss-lock -n /usr/libexec/xsecurelock/dimmer -l -- xsecurelock &
    xautolock -time 15 -locker "systemctl suspend-then-hibernate" -detectsleep &
}

main

